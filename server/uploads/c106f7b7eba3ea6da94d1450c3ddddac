<!DOCTYPE html>
<html lang="en" xmlns:th="http://www.thymeleaf.org">
<head>
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <style>
        @page {
          size: A4 portrait;
          margin: 100px 25px 180px;

          @bottom-right {
            content: counter(page) "/" counter(pages);
            font-size: 12px;
            white-space: nowrap;
          }

          @bottom-left {
            content: element(footer);
          }

          @bottom-center {
            content: element(pageFooter);
          }

          @top-right {
            content: element(pageHeader);
          }

          counter-increment: page;
          counter-reset: page 1;
        }

        .avoid-tr-breaks tr {
          page-break-inside: avoid;
        }

        h1 {
          text-align: right;
          margin-right: 20px;
          margin-top: 40px;
        }

        h2,
        h3 {
          text-align: center;
        }

        th {
          border: 1px solid black;
          text-align: center;
          padding: 10px;
          width: 5px;
        }

        .annexABC-table {
          border-collapse: collapse;
          width: 100%;
          margin: auto;
          table-layout: auto;
        }

        .first-col {
          width: 5%;
          text-align: center;
          border: 1px solid black;
          word-wrap: break-word;
        }

        .second-col {
          width: 30%;
          border: 1px solid black;
          text-align: left;
          word-wrap: break-word;
        }

        .third-col {
          width: 65%;
          border: 1px solid black;
          text-align: left;
          word-wrap: break-word;
        }

        .page-break {
          page-break-before: always;
        }

        #pageFooter {
          position: running(pageFooter);
          font-size: 10px;
          text-align: center;
        }

        #pageFooter table {
          width: 100%;
          margin: 0 auto;
        }

        #pageHeader {
          position: running(pageHeader);
          text-align: right;
          padding-bottom: 60px;
          width: 100%;
          display: block;
        }

        #pageHeader img {
          display: block;
          margin-left: auto;
          margin-right: 0;
          float: right;
        }
    </style>
    <title>KFS Document</title>
</head>

