# Copy to .env and fill values
# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# Translation defaults
DEFAULT_SOURCE_LANG=en
MAX_TRANSLATION_TEXT_LENGTH=5000

# Optional provider endpoints (override only if you run self-hosted services)
# Other provider endpoints removed — this project uses OpenAI only.

# Server
PORT=5000
